+// Era-style attribute scaling for levels 37-75
+static float getEraScaling(int level, float startValue, float endValue) {
+    if (level < 37) return startValue;
+    if (level >= 75) return endValue;
+    return startValue + (endValue - startValue) * ((level - 37) / 38.0f);
+}
