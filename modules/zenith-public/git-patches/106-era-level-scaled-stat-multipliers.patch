diff --git a/src/map/entities/battleentity.cpp b/src/map/entities/battleentity.cpp
index 8dc0223259..44e4e8c24a 100644
--- a/src/map/entities/battleentity.cpp
+++ b/src/map/entities/battleentity.cpp
@@ -55,6 +55,20 @@
 #include "utils/zoneutils.h"
 #include "weapon_skill.h"
 
+static float GetEraScaledMultiplier(uint8 level, float startValue, float endValue)
+{
+    if (level < 37)
+    {
+        return startValue;
+    }
+    else if (level >= 75)
+    {
+        return endValue;
+    }
+
+    return startValue + (endValue - startValue) * ((level - 37) / 38.0f);
+}
